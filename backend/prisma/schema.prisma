// Prisma Schema - Delivery Platform
// Única fonte de verdade para o modelo de dados

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================
// ENUMS
// ===========================================

enum UserRole {
  CUSTOMER
  MERCHANT
  DRIVER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum MerchantStatus {
  PENDING_APPROVAL
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentIntentStatus {
  CREATED
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  PIX
  CASH
}

enum AdminAction {
  MERCHANT_APPROVED
  MERCHANT_SUSPENDED
  MERCHANT_ACTIVATED
  MERCHANT_REJECTED
  DRIVER_APPROVED
  DRIVER_SUSPENDED
  DRIVER_ACTIVATED
  DRIVER_REJECTED
  ORDER_CANCELLED
  ORDER_REFUNDED
  USER_SUSPENDED
  USER_ACTIVATED
  USER_ROLE_CHANGED
  PAYMENT_REFUNDED
  SYSTEM_CONFIG_CHANGED
}

enum DriverStatus {
  PENDING_APPROVAL
  APPROVED
  ONLINE
  OFFLINE
  ON_DELIVERY
  SUSPENDED
}

enum VehicleType {
  BICYCLE
  MOTORCYCLE
  CAR
  VAN
}

enum CouponType {
  PERCENT
  FIXED
}

// ===========================================
// MODELS
// ===========================================

model User {
  id                String     @id @default(cuid())
  email             String     @unique
  passwordHash      String     @map("password_hash")
  firstName         String     @map("first_name")
  lastName          String     @map("last_name")
  phone             String?
  role              UserRole   @default(CUSTOMER)
  status            UserStatus @default(PENDING_VERIFICATION)
  emailVerifiedAt   DateTime?  @map("email_verified_at")
  lastLoginAt       DateTime?  @map("last_login_at")
  
  // Super App - Perfil público
  userHandle        String?    @unique @map("user_handle") // @usuario único
  avatarUrl         String?    @map("avatar_url")
  bio               String?
  
  // Push Notifications
  pushToken         String?    @map("push_token") // FCM/Expo token
  pushTokenUpdatedAt DateTime? @map("push_token_updated_at")
  
  // Social Login IDs
  googleId          String?    @unique @map("google_id")
  appleId           String?    @unique @map("apple_id")
  facebookId        String?    @unique @map("facebook_id")
  profilePicture    String?    @map("profile_picture")
  
  // Localização padrão (para feed e listings)
  defaultCity       String?    @map("default_city")
  defaultState      String?    @map("default_state")
  defaultLatitude   Decimal?   @db.Decimal(10, 8) @map("default_latitude")
  defaultLongitude  Decimal?   @db.Decimal(11, 8) @map("default_longitude")
  
  // LGPD: Registro de consentimento
  acceptedTermsAt   DateTime?  @map("accepted_terms_at")
  acceptedPrivacyAt DateTime?  @map("accepted_privacy_at")
  
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  deletedAt         DateTime?  @map("deleted_at")
  
  // Relacionamentos existentes
  merchant          Merchant?
  driverProfile     DriverProfile?
  customerOrders    Order[]    @relation("CustomerOrders")
  driverOrders      Order[]    @relation("DriverOrders")
  addresses         Address[]
  refreshTokens     RefreshToken[]
  passwordResets    PasswordReset?
  adminAuditLogs    AdminAuditLog[]
  reviews           Review[]
  
  // Super App - Novos relacionamentos
  listings          Listing[]
  listingFavorites  ListingFavorite[]
  conversationsAsP1 Conversation[] @relation("ConversationParticipant1")
  conversationsAsP2 Conversation[] @relation("ConversationParticipant2")
  messages          Message[]
  
  @@index([email])
  @@index([role])
  @@index([status])
  @@index([userHandle])
  @@index([defaultCity, defaultState])
  @@map("users")
}

model RefreshToken {
  id          String   @id @default(cuid())
  token       String   @unique
  userId      String   @map("user_id")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")
  revokedAt   DateTime? @map("revoked_at")
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// OTP Code for phone verification
model OtpCode {
  id          String   @id @default(cuid())
  phone       String   @unique
  code        String   // hashed
  expiresAt   DateTime @map("expires_at")
  attempts    Int      @default(0)
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  @@index([phone])
  @@map("otp_codes")
}

// Phone verification token (after OTP is verified)
model PhoneVerification {
  id          String   @id @default(cuid())
  phone       String   @unique
  token       String
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")
  
  @@index([phone])
  @@index([token])
  @@map("phone_verifications")
}

// Password reset token
model PasswordReset {
  id          String    @id @default(cuid())
  userId      String    @unique @map("user_id")
  token       String    // hashed
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([token])
  @@map("password_resets")
}

model Address {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  label         String?  // Casa, Trabalho, etc.
  street        String
  number        String
  complement    String?
  neighborhood  String
  city          String
  state         String
  zipCode       String   @map("zip_code")
  latitude      Decimal? @db.Decimal(10, 8)
  longitude     Decimal? @db.Decimal(11, 8)
  isDefault     Boolean  @default(false) @map("is_default")
  
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders        Order[]
  
  @@index([userId])
  @@map("addresses")
}

model Merchant {
  id              String         @id @default(cuid())
  userId          String         @unique @map("user_id")
  businessName    String         @map("business_name")
  tradeName       String?        @map("trade_name")
  document        String         @unique // CNPJ
  description     String?
  logoUrl         String?        @map("logo_url")
  bannerUrl       String?        @map("banner_url")
  
  // Endereço do estabelecimento
  street          String
  number          String
  complement      String?
  neighborhood    String
  city            String
  state           String
  zipCode         String         @map("zip_code")
  latitude        Decimal?       @db.Decimal(10, 8)
  longitude       Decimal?       @db.Decimal(11, 8)
  
  // Configurações
  status          MerchantStatus @default(PENDING_APPROVAL)
  isOpen          Boolean        @default(false) @map("is_open")
  minimumOrder    Decimal        @default(0) @db.Decimal(10, 2) @map("minimum_order")
  deliveryFee     Decimal        @default(0) @db.Decimal(10, 2) @map("delivery_fee")
  estimatedTime   Int            @default(30) @map("estimated_time") // minutos
  
  // Avaliações
  averageRating   Decimal?       @db.Decimal(3, 2) @map("average_rating")
  totalReviews    Int            @default(0) @map("total_reviews")
  
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")
  
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories      Category[]
  products        Product[]
  orders          Order[]
  reviews         Review[]
  coupons         Coupon[]
  platformFees    PlatformFee[]
  
  @@index([status])
  @@index([city, state])
  @@map("merchants")
}

model Category {
  id          String    @id @default(cuid())
  merchantId  String    @map("merchant_id")
  name        String
  description String?
  imageUrl    String?   @map("image_url")
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  
  merchant    Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  products    Product[]
  
  @@index([merchantId])
  @@map("categories")
}

model Product {
  id              String      @id @default(cuid())
  merchantId      String      @map("merchant_id")
  categoryId      String?     @map("category_id")
  name            String
  description     String?
  price           Decimal     @db.Decimal(10, 2)
  originalPrice   Decimal?    @db.Decimal(10, 2) @map("original_price")
  imageUrl        String?     @map("image_url")
  isAvailable     Boolean     @default(true) @map("is_available")
  sortOrder       Int         @default(0) @map("sort_order")
  preparationTime Int         @default(20) @map("preparation_time")
  
  // Controle de estoque básico
  hasStock    Boolean     @default(false) @map("has_stock")
  stockQty    Int?        @map("stock_qty")
  
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")
  
  merchant    Merchant    @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  category    Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems  OrderItem[]
  
  @@index([merchantId])
  @@index([categoryId])
  @@index([isAvailable])
  @@map("products")
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique @map("order_number")
  customerId      String        @map("customer_id")
  merchantId      String        @map("merchant_id")
  driverId        String?       @map("driver_id")
  addressId       String        @map("address_id")
  couponId        String?       @map("coupon_id")
  
  status          OrderStatus   @default(PENDING)
  
  // Valores
  subtotal        Decimal       @db.Decimal(10, 2)
  deliveryFee     Decimal       @db.Decimal(10, 2) @map("delivery_fee")
  discount        Decimal       @default(0) @db.Decimal(10, 2)
  couponCode      String?       @map("coupon_code") // Snapshot do código usado
  platformFee     Decimal       @default(0) @db.Decimal(10, 2) @map("platform_fee") // Taxa da plataforma
  total           Decimal       @db.Decimal(10, 2)
  merchantNet     Decimal?      @db.Decimal(10, 2) @map("merchant_net") // Valor líquido do merchant
  
  // Pagamento
  paymentMethod   PaymentMethod @map("payment_method")
  paymentStatus   PaymentStatus @default(PENDING) @map("payment_status")
  
  // Observações
  notes           String?
  
  // Timestamps de status
  confirmedAt     DateTime?     @map("confirmed_at")
  preparingAt     DateTime?     @map("preparing_at")
  readyAt         DateTime?     @map("ready_at")
  pickedUpAt      DateTime?     @map("picked_up_at")
  deliveredAt     DateTime?     @map("delivered_at")
  cancelledAt     DateTime?     @map("cancelled_at")
  cancellationReason String?    @map("cancellation_reason")
  
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  
  customer        User          @relation("CustomerOrders", fields: [customerId], references: [id])
  merchant        Merchant      @relation(fields: [merchantId], references: [id])
  driver          User?         @relation("DriverOrders", fields: [driverId], references: [id])
  address         Address       @relation(fields: [addressId], references: [id])
  coupon          Coupon?       @relation(fields: [couponId], references: [id])
  items           OrderItem[]
  paymentIntent   PaymentIntent?
  review          Review?
  
  @@index([customerId])
  @@index([merchantId])
  @@index([driverId])
  @@index([status])
  @@index([orderNumber])
  @@index([createdAt])
  @@index([couponId])
  @@map("orders")
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String   @map("order_id")
  productId   String   @map("product_id")
  productName String   @map("product_name") // Snapshot do nome
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2) @map("unit_price") // Snapshot do preço
  totalPrice  Decimal  @db.Decimal(10, 2) @map("total_price")
  notes       String?
  
  createdAt   DateTime @default(now()) @map("created_at")
  
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])
  
  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// ===========================================
// PAYMENTS
// ===========================================

model PaymentIntent {
  id              String              @id @default(cuid())
  orderId         String              @unique @map("order_id")
  amount          Decimal             @db.Decimal(10, 2)
  currency        String              @default("BRL")
  method          PaymentMethod
  status          PaymentIntentStatus @default(CREATED)
  
  // Referência externa (ex: Mercado Pago, Stripe)
  externalId      String?             @map("external_id")
  externalStatus  String?             @map("external_status")
  
  // Metadados (não sensíveis)
  metadata        Json?
  
  // Timestamps
  expiresAt       DateTime?           @map("expires_at")
  processedAt     DateTime?           @map("processed_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  
  order           Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payments        Payment[]
  
  @@index([orderId])
  @@index([externalId])
  @@index([status])
  @@map("payment_intents")
}

model Payment {
  id                String        @id @default(cuid())
  paymentIntentId   String        @map("payment_intent_id")
  amount            Decimal       @db.Decimal(10, 2)
  status            PaymentStatus @default(PENDING)
  
  // Referência externa
  externalId        String?       @map("external_id")
  externalStatus    String?       @map("external_status")
  
  // Informações do pagamento (não sensíveis)
  // Apenas últimos 4 dígitos do cartão, se aplicável
  cardLast4         String?       @map("card_last_4")
  cardBrand         String?       @map("card_brand")
  
  // PIX
  pixKey            String?       @map("pix_key")
  pixQrCode         String?       @map("pix_qr_code")
  
  // Erro/Falha
  failureCode       String?       @map("failure_code")
  failureMessage    String?       @map("failure_message")
  
  // Refund
  refundedAt        DateTime?     @map("refunded_at")
  refundReason      String?       @map("refund_reason")
  refundAmount      Decimal?      @db.Decimal(10, 2) @map("refund_amount")
  
  // Timestamps
  paidAt            DateTime?     @map("paid_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  
  paymentIntent     PaymentIntent @relation(fields: [paymentIntentId], references: [id], onDelete: Cascade)
  
  @@index([paymentIntentId])
  @@index([externalId])
  @@index([status])
  @@map("payments")
}

// ===========================================
// ADMIN / AUDIT
// ===========================================

model AdminAuditLog {
  id            String      @id @default(cuid())
  adminId       String      @map("admin_id")
  action        AdminAction
  targetType    String      @map("target_type") // 'merchant', 'order', 'user', 'payment'
  targetId      String      @map("target_id")
  
  // Detalhes da ação
  previousValue Json?       @map("previous_value")
  newValue      Json?       @map("new_value")
  reason        String?
  metadata      Json?
  
  // IP e User Agent para auditoria
  ipAddress     String?     @map("ip_address")
  userAgent     String?     @map("user_agent")
  
  createdAt     DateTime    @default(now()) @map("created_at")
  
  admin         User        @relation(fields: [adminId], references: [id])
  
  @@index([adminId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

// ===========================================
// DRIVERS
// ===========================================

model DriverProfile {
  id              String        @id @default(cuid())
  userId          String        @unique @map("user_id")
  
  // Documentos
  cpf             String        @unique
  cnh             String?       // CNH para motos/carros
  cnhCategory     String?       @map("cnh_category") // A, AB, B, etc.
  cnhExpiry       DateTime?     @map("cnh_expiry")
  
  // Veículo
  vehicleType     VehicleType   @map("vehicle_type")
  vehiclePlate    String?       @map("vehicle_plate")
  vehicleModel    String?       @map("vehicle_model")
  vehicleYear     Int?          @map("vehicle_year")
  vehicleColor    String?       @map("vehicle_color")
  
  // Foto e documentos
  photoUrl        String?       @map("photo_url")
  documentUrl     String?       @map("document_url") // Foto do documento
  
  // Status e disponibilidade
  status          DriverStatus  @default(PENDING_APPROVAL)
  isAvailable     Boolean       @default(false) @map("is_available")
  
  // Localização atual (cache para queries rápidas)
  currentLat      Decimal?      @db.Decimal(10, 8) @map("current_lat")
  currentLng      Decimal?      @db.Decimal(11, 8) @map("current_lng")
  lastLocationAt  DateTime?     @map("last_location_at")
  
  // Métricas (atualizadas periodicamente)
  totalDeliveries Int           @default(0) @map("total_deliveries")
  averageRating   Decimal?      @db.Decimal(3, 2) @map("average_rating")
  totalRatings    Int           @default(0) @map("total_ratings")
  
  // Configurações de área
  maxDeliveryRadius Int         @default(10) @map("max_delivery_radius") // km
  
  // Financeiro
  balance         Decimal       @default(0) @db.Decimal(10, 2) // Saldo a receber
  
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  approvedAt      DateTime?     @map("approved_at")
  suspendedAt     DateTime?     @map("suspended_at")
  
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  locations       DriverLocation[]
  reviews         Review[]      @relation("DriverReviews")
  
  @@index([status])
  @@index([vehicleType])
  @@index([isAvailable])
  @@index([currentLat, currentLng])
  @@map("driver_profiles")
}

model DriverLocation {
  id          String    @id @default(cuid())
  driverId    String    @map("driver_id")
  
  latitude    Decimal   @db.Decimal(10, 8)
  longitude   Decimal   @db.Decimal(11, 8)
  accuracy    Float?    // Precisão em metros
  heading     Float?    // Direção em graus
  speed       Float?    // Velocidade em km/h
  
  // Contexto
  orderId     String?   @map("order_id") // Se estiver em entrega
  
  createdAt   DateTime  @default(now()) @map("created_at")
  
  driver      DriverProfile @relation(fields: [driverId], references: [id], onDelete: Cascade)
  
  @@index([driverId])
  @@index([createdAt])
  @@index([orderId])
  @@map("driver_locations")
}

// ===========================================
// REVIEWS
// ===========================================

model Review {
  id            String         @id @default(cuid())
  orderId       String         @unique @map("order_id")
  customerId    String         @map("customer_id")
  merchantId    String         @map("merchant_id")
  driverId      String?        @map("driver_id")
  
  // Avaliações
  merchantRating Int           @map("merchant_rating") // 1-5
  driverRating   Int?          @map("driver_rating")   // 1-5
  
  // Comentários
  merchantComment String?      @map("merchant_comment")
  driverComment   String?      @map("driver_comment")
  
  // Resposta do comerciante
  merchantReply    String?     @map("merchant_reply")
  merchantRepliedAt DateTime?  @map("merchant_replied_at")
  
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  
  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer      User           @relation(fields: [customerId], references: [id])
  merchant      Merchant       @relation(fields: [merchantId], references: [id])
  driver        DriverProfile? @relation("DriverReviews", fields: [driverId], references: [id])
  
  @@index([merchantId])
  @@index([customerId])
  @@index([driverId])
  @@index([createdAt])
  @@map("reviews")
}

// ===========================================
// COUPONS
// ===========================================

model Coupon {
  id            String      @id @default(cuid())
  code          String      @unique
  type          CouponType  // PERCENT ou FIXED
  value         Decimal     @db.Decimal(10, 2) // Percentual ou valor fixo
  
  // Limites
  maxUses       Int?        @map("max_uses")      // Null = ilimitado
  currentUses   Int         @default(0) @map("current_uses")
  maxUsesPerUser Int?       @map("max_uses_per_user")
  
  // Validade
  startsAt      DateTime?   @map("starts_at")
  expiresAt     DateTime?   @map("expires_at")
  
  // Restrições
  minOrderValue Decimal?    @db.Decimal(10, 2) @map("min_order_value")
  maxDiscount   Decimal?    @db.Decimal(10, 2) @map("max_discount") // Limite máximo para cupons percentuais
  
  // Escopo: null = global, merchantId = específico para merchant
  merchantId    String?     @map("merchant_id")
  
  // Descrição
  description   String?
  
  // Status
  isActive      Boolean     @default(true) @map("is_active")
  
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")
  
  merchant      Merchant?   @relation(fields: [merchantId], references: [id])
  orders        Order[]
  
  @@index([code])
  @@index([merchantId])
  @@index([isActive])
  @@index([expiresAt])
  @@map("coupons")
}

// ===========================================
// PLATFORM FEES
// ===========================================

model PlatformFee {
  id            String    @id @default(cuid())
  name          String    // Nome identificador da taxa
  description   String?   // Descrição da taxa
  
  // Tipos de taxa
  percentage    Decimal?  @db.Decimal(5, 2) // Comissão percentual (ex: 10.00 = 10%)
  fixedFee      Decimal?  @db.Decimal(10, 2) @map("fixed_fee") // Taxa fixa por pedido
  deliveryFee   Decimal?  @db.Decimal(10, 2) @map("delivery_fee") // Taxa adicional na entrega
  
  // Escopo: null = taxa global, merchantId = específico para merchant
  merchantId    String?   @map("merchant_id")
  
  // Limites
  minOrderValue Decimal?  @db.Decimal(10, 2) @map("min_order_value") // Valor mínimo para aplicar
  maxFee        Decimal?  @db.Decimal(10, 2) @map("max_fee") // Teto máximo da taxa
  
  // Status
  isActive      Boolean   @default(true) @map("is_active")
  priority      Int       @default(0) // Prioridade (maior = preferência)
  
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  
  merchant      Merchant? @relation(fields: [merchantId], references: [id])
  
  @@index([merchantId])
  @@index([isActive])
  @@index([priority])
  @@map("platform_fees")
}

// ===========================================
// SUPER APP - LISTINGS (Marketplace)
// ===========================================

enum ListingCategory {
  PRODUCTS
  SERVICES
  VEHICLES
  REAL_ESTATE
  JOBS
  FOOD
  ELECTRONICS
  FASHION
  HOME_GARDEN
  SPORTS
  PETS
  OTHER
}

enum ListingStatus {
  DRAFT
  ACTIVE
  SOLD
  EXPIRED
  REMOVED
}

model Listing {
  id            String          @id @default(cuid())
  userId        String          @map("user_id")
  
  // Conteúdo
  title         String
  description   String?
  price         Decimal?        @db.Decimal(10, 2)
  priceType     String          @default("FIXED") @map("price_type") // FIXED, NEGOTIABLE, FREE, CONTACT
  images        String[]        // Array de URLs
  audioUrl      String?         @map("audio_url") // URL do áudio da postagem
  
  // Categorização
  category      ListingCategory
  subcategory   String?
  tags          String[]
  
  // Localização
  city          String?
  state         String?
  neighborhood  String?
  latitude      Decimal?        @db.Decimal(10, 8)
  longitude     Decimal?        @db.Decimal(11, 8)
  
  // Status e configurações
  status        ListingStatus   @default(ACTIVE)
  viewCount     Int             @default(0) @map("view_count")
  favoriteCount Int             @default(0) @map("favorite_count")
  isFeatured    Boolean         @default(false) @map("is_featured")
  
  // Criado via IA
  aiGenerated   Boolean         @default(false) @map("ai_generated")
  aiMetadata    Json?           @map("ai_metadata") // Dados extraídos pela IA
  
  // Timestamps
  expiresAt     DateTime?       @map("expires_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  deletedAt     DateTime?       @map("deleted_at")
  
  // Relacionamentos
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  favorites     ListingFavorite[]
  
  @@index([userId])
  @@index([category])
  @@index([status])
  @@index([city, state])
  @@index([createdAt])
  @@index([isFeatured])
  @@map("listings")
}

model ListingFavorite {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  listingId   String   @map("listing_id")
  createdAt   DateTime @default(now()) @map("created_at")
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  
  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
  @@map("listing_favorites")
}

// ===========================================
// SUPER APP - CHAT (Mensageiro)
// ===========================================

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  SYSTEM
}

model Conversation {
  id              String    @id @default(cuid())
  // Participantes
  participant1Id  String    @map("participant1_id")
  participant2Id  String    @map("participant2_id")
  
  // Contexto opcional (ex: sobre um anúncio)
  listingId       String?   @map("listing_id")
  
  // Última mensagem (cache para listar conversas)
  lastMessageAt   DateTime? @map("last_message_at")
  lastMessageText String?   @map("last_message_text")
  
  // Status por participante
  participant1UnreadCount Int @default(0) @map("participant1_unread_count")
  participant2UnreadCount Int @default(0) @map("participant2_unread_count")
  
  // Timestamps
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  // Relacionamentos
  participant1    User      @relation("ConversationParticipant1", fields: [participant1Id], references: [id], onDelete: Cascade)
  participant2    User      @relation("ConversationParticipant2", fields: [participant2Id], references: [id], onDelete: Cascade)
  messages        Message[]
  
  @@unique([participant1Id, participant2Id, listingId])
  @@index([participant1Id])
  @@index([participant2Id])
  @@index([lastMessageAt])
  @@map("conversations")
}

model Message {
  id              String      @id @default(cuid())
  conversationId  String      @map("conversation_id")
  senderId        String      @map("sender_id")
  
  // Conteúdo
  type            MessageType @default(TEXT)
  content         String      // Texto ou URL da mídia
  metadata        Json?       // Metadados adicionais (ex: duração do áudio)
  
  // Status
  readAt          DateTime?   @map("read_at")
  
  // Timestamps
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  deletedAt       DateTime?   @map("deleted_at")
  
  // Relacionamentos
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  
  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@map("messages")
}

// ===========================================
// SUPER APP - SPONSORS (Patrocinadores)
// ===========================================

enum SponsorPlacement {
  HOME_BANNER
  CATEGORY_HEADER
  FEED_INLINE
  SEARCH_RESULTS
  LISTING_DETAIL
  FEATURED_CAROUSEL
}

model Sponsor {
  id          String            @id @default(cuid())
  name        String
  description String?
  logoUrl     String?           @map("logo_url")
  bannerUrl   String?           @map("banner_url")
  websiteUrl  String?           @map("website_url")
  
  // Configurações de exibição
  placements  SponsorPlacement[]
  priority    Int               @default(0) // Maior = mais destaque
  
  // Segmentação
  targetCities     String[]     @map("target_cities")
  targetCategories ListingCategory[] @map("target_categories")
  
  // Período ativo
  startDate   DateTime          @map("start_date")
  endDate     DateTime          @map("end_date")
  
  // Status
  isActive    Boolean           @default(true) @map("is_active")
  
  // Métricas
  impressions Int               @default(0)
  clicks      Int               @default(0)
  
  // Timestamps
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  
  @@index([isActive])
  @@index([startDate, endDate])
  @@index([priority])
  @@map("sponsors")
}

// ===========================================
// SUPER APP - COMMUNITY FEED
// ===========================================

enum FeedItemType {
  NEW_LISTING
  PROMOTION
  NEW_MERCHANT
  SPONSORED
  ANNOUNCEMENT
  EVENT
}

model CommunityFeedItem {
  id          String        @id @default(cuid())
  type        FeedItemType
  
  // Conteúdo
  title       String
  description String?
  imageUrl    String?       @map("image_url")
  linkUrl     String?       @map("link_url")
  
  // Referência a entidade (opcional)
  listingId   String?       @map("listing_id")
  merchantId  String?       @map("merchant_id")
  sponsorId   String?       @map("sponsor_id")
  
  // Localização do feed item
  city        String?
  state       String?
  
  // Configurações
  priority    Int           @default(0)
  isActive    Boolean       @default(true) @map("is_active")
  
  // Período ativo (opcional)
  startDate   DateTime?     @map("start_date")
  endDate     DateTime?     @map("end_date")
  
  // Timestamps
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  
  @@index([type])
  @@index([city, state])
  @@index([isActive])
  @@index([createdAt])
  @@map("community_feed_items")
}

# Delivery Platform - Environment Variables
# Copie este arquivo para .env e preencha os valores

# ===========================================
# Application
# ===========================================
NODE_ENV=development
PORT=3000
APP_VERSION=0.1.0
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ===========================================
# Database (PostgreSQL)
# ===========================================
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/delivery_platform?schema=public"

# ===========================================
# JWT / Authentication
# ===========================================
# Gere uma chave segura: openssl rand -base64 64
JWT_SECRET="CHANGE_ME_GENERATE_A_SECURE_SECRET_KEY"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="CHANGE_ME_GENERATE_ANOTHER_SECURE_SECRET_KEY"
JWT_REFRESH_EXPIRES_IN="7d"

# ===========================================
# Redis (Cache / Sessions)
# ===========================================
REDIS_URL="redis://localhost:6379"

# ===========================================
# Mercado Pago (Payments) - Stub no MVP
# ===========================================
MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_PUBLIC_KEY=""
MERCADO_PAGO_WEBHOOK_SECRET=""

# ===========================================
# File Upload (S3 Compatible - R2/S3/MinIO)
# ===========================================
# Cloudflare R2 example:
# S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
# S3_PUBLIC_URL=https://pub-xxx.r2.dev
# 
# AWS S3 example:
# S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
# S3_PUBLIC_URL=https://bucket-name.s3.amazonaws.com
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET="delivery-uploads"
S3_REGION="auto"
S3_PUBLIC_URL=""

# ===========================================
# Email (SMTP)
# ===========================================
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@delivery-platform.com"

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=debug

# ===========================================
# Firebase (Push Notifications)
# ===========================================
# Get these from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# ===========================================
# App Config
# ===========================================
APP_NAME="Delivery App"

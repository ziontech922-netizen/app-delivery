# Super App Mobile Client - Beta Environment
# Para usar: copie este arquivo para .env e rode o app

# API Beta
EXPO_PUBLIC_API_URL=https://superapp-api-beta.fly.dev/api/v1

# Socket.IO Beta
EXPO_PUBLIC_SOCKET_URL=https://superapp-api-beta.fly.dev

# Beta Mode Flag
EXPO_PUBLIC_BETA_MODE=true

# Debug Features
EXPO_PUBLIC_ENABLE_DEV_MENU=true
EXPO_PUBLIC_LOG_LEVEL=debug
